# Backend API base URL (example)
# Local: http://localhost:8080/api
# Production: https://<your-backend-domain>/api
VITE_API_BASE_URL=http://localhost:8080/api

# fetch timeout (ms)
VITE_API_TIMEOUT_MS=10000

# For shared usage, set this to false so everyone always uses the same backend data.
VITE_API_USE_LOCAL_FALLBACK=false
